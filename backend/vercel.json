{
  "version": 2,
  "builds": [
    {
      "src": "backend/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/javascripts/(.*)",
      "dest": "/frontend/javascripts/$1"
    },
    {
      "src": "/styles/(.*)",
      "dest": "/frontend/styles/$1"
    },
    {
      "src": "/(.*)",
      "dest": "backend/app.js"
    }
  ]
}